#!/bin/sh
. /usr/share/libubox/jshn.sh

case "$1" in
  list)
    echo '{"status":{},"pricing":{},"wallet_balance":{},"wallet_drain":{"method":"string"},"activate":{"token":"string","type":"string","amount":0},"configure":{"pricing_model":"string","price_per_unit":0,"min_purchase":0,"lnurl":"string","password":"string","hostname":"string"},"sessions":{}}'
    ;;
  call)
    case "$2" in
      status)
        OUTPUT=$(tollgate status 2>&1 || echo "not running")
        json_init
        json_add_string "output" "$OUTPUT"
        json_add_string "service" "$(pgrep -f tollgate-basic > /dev/null && echo 'running' || echo 'stopped')"
        json_dump
        ;;
      pricing)
        json_init
        json_add_string "model" "$(uci -q get tollgate.pricing.model || echo 'time')"
        json_add_string "price_per_unit" "$(uci -q get tollgate.pricing.price || echo '1')"
        json_add_string "min_purchase" "$(uci -q get tollgate.pricing.min || echo '5')"
        json_add_string "currency" "$(uci -q get tollgate.pricing.currency || echo 'sat')"
        json_dump
        ;;
      wallet_balance)
        OUTPUT=$(tollgate wallet balance 2>&1 || echo '{"error":"wallet not available"}')
        echo "$OUTPUT"
        ;;
      wallet_drain)
        INPUT=$(cat)
        METHOD=$(echo "$INPUT" | jsonfilter -e '@.method' 2>/dev/null || echo "cashu")
        OUTPUT=$(tollgate wallet drain "$METHOD" 2>&1 || echo '{"error":"drain failed"}')
        echo "$OUTPUT"
        ;;
      activate)
        INPUT=$(cat)
        TOKEN=$(echo "$INPUT" | jsonfilter -e '@.token' 2>/dev/null)
        TYPE=$(echo "$INPUT" | jsonfilter -e '@.type' 2>/dev/null)
        AMOUNT=$(echo "$INPUT" | jsonfilter -e '@.amount' 2>/dev/null)
        if [ -n "$TOKEN" ]; then
          OUTPUT=$(tollgate activate --token "$TOKEN" --type "$TYPE" --amount "$AMOUNT" 2>&1)
        else
          OUTPUT=$(tollgate activate --type "$TYPE" --amount "$AMOUNT" 2>&1)
        fi
        json_init
        json_add_string "result" "$OUTPUT"
        json_dump
        ;;
      configure)
        INPUT=$(cat)
        PRICING_MODEL=$(echo "$INPUT" | jsonfilter -e '@.pricing_model' 2>/dev/null)
        PRICE=$(echo "$INPUT" | jsonfilter -e '@.price_per_unit' 2>/dev/null)
        MIN_PURCHASE=$(echo "$INPUT" | jsonfilter -e '@.min_purchase' 2>/dev/null)
        LNURL=$(echo "$INPUT" | jsonfilter -e '@.lnurl' 2>/dev/null)
        PASSWORD=$(echo "$INPUT" | jsonfilter -e '@.password' 2>/dev/null)
        HOSTNAME=$(echo "$INPUT" | jsonfilter -e '@.hostname' 2>/dev/null)
        
        [ -n "$PRICING_MODEL" ] && uci set tollgate.pricing.model="$PRICING_MODEL"
        [ -n "$PRICE" ] && uci set tollgate.pricing.price="$PRICE"
        [ -n "$MIN_PURCHASE" ] && uci set tollgate.pricing.min="$MIN_PURCHASE"
        [ -n "$LNURL" ] && uci set tollgate.lightning.lnurl="$LNURL"
        [ -n "$HOSTNAME" ] && { uci set system.@system[0].hostname="$HOSTNAME"; /etc/init.d/system reload; }
        [ -n "$PASSWORD" ] && printf '%s' "$PASSWORD" | passwd root >/dev/null 2>&1
        
        uci commit tollgate 2>/dev/null
        /etc/init.d/tollgate-basic restart 2>/dev/null
        
        json_init
        json_add_string "status" "ok"
        json_dump
        ;;
      sessions)
        OUTPUT=$(tollgate sessions 2>&1 || echo "no active sessions")
        json_init
        json_add_string "output" "$OUTPUT"
        json_dump
        ;;
    esac
    ;;
esac
