  "main": "index.js",
  "scripts": {
    "dev": "VITE_APP=admin vite",
    "dev:portal": "VITE_APP=portal vite",
    "dev:admin": "VITE_APP=admin vite",
    "build": "node scripts/build-app.mjs",
    "build:admin": "VITE_APP=admin vite build",
    "build:portal": "VITE_APP=portal vite build",
    "preview": "vite preview",
    "demo": "VITE_MOCK=true VITE_APP=admin vite",
    "build:demo": "VITE_MOCK=true VITE_APP=admin vite build",
    "build:pages": "VITE_MOCK=true VITE_BASE_PATH=/configurationwizzard/ node scripts/build-pages.mjs",
    "postinstall": "node -e \"const p=require('path').join(process.cwd(),'node_modules/zimmerframe/package.json');const d=require('fs').readFileSync(p,'utf8');const j=JSON.parse(d);j.main='./src/walk.js';j.exports['.'].require='./src/walk.js';require('fs').writeFileSync(p,JSON.stringify(j,null,2))\""
  },
